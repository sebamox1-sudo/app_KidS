# ============================================================
# KIDS BACKEND — variabili d'ambiente
# Copia questo file in .env e compila i valori
# MAI committare .env su GitHub!
# ============================================================

# Database PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/kids_db

# JWT — chiave segreta per firmare i token
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_questa_chiave_con_una_sicura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 giorni

# Upload foto
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Firebase (per notifiche push) — opzionale per ora
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Ambiente
ENVIRONMENT=development  # development / production
